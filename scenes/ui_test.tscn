[sub_resource type="GDScript" id="GDScript_vnxhw"]
resource_name = "Temporary_test"
script/source = "extends Control


# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	self.get_node(\"Start/Quit\").pressed.connect(func():
		get_tree().quit()
	)
	self.get_node(\"Start/Settings\").pressed.connect(func():
		self.get_node(\"Settings/Anims\").play(\"Open\")
	)
	self.get_node(\"Settings/Nav/Close\").pressed.connect(func():
		self.get_node(\"Settings/Anims\").play(\"Close\")
	)
"

